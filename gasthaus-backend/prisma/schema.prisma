generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum Role {
  CUSTOMER
  WAITER
  KITCHEN
  MANAGER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  reviews    Review[]
  aiSessions AiSession[]
}

model MenuCategory {
  id    String     @id @default(uuid())
  name  String
  icon  String?
  items MenuItem[]
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   MenuCategory @relation(fields: [categoryId], references: [id])
  categoryId String

  orderItems  OrderItem[]
  reviews     Review[]
}

model RestaurantTable {
  id          String  @id @default(uuid())
  tableNumber Int     @unique
  qrCode      String  @unique
  isOccupied  Boolean @default(false)

  orders Order[]
}

model Order {
  id          String      @id @default(uuid())
  status      OrderStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer   User            @relation(fields: [customerId], references: [id])
  customerId String

  table   RestaurantTable @relation(fields: [tableId], references: [id])
  tableId String

  items   OrderItem[]
  reviews Review[]
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  notes     String?

  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String

  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  customer   User   @relation(fields: [customerId], references: [id])
  customerId String

  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  @@unique([customerId, menuItemId, orderId])
}
model AiSession {
  id        String   @id @default(uuid())
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String
}