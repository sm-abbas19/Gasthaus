# Copy this file to application-local.properties and fill in real values.
# application-local.properties is gitignored and never committed.

DB_URL=jdbc:postgresql://localhost:5432/gasthaus
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long

# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis and FastAPI — defaults work for local Docker setup
REDIS_URL=redis://localhost:6379
FASTAPI_URL=http://localhost:8000
